          },
          "expected_result": "创建蓝色连接线",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 4,
          "action": "验证蓝色连接线存在",
          "mcp_tool": "mcp1_browser_evaluate",
          "mcp_params": {
            "function": "() => { return { connCount: document.querySelectorAll('.first-frame-conn-group').length, firstFrameConns: window.state ? window.state.firstFrameConnections.length : 0 }; }"
          },
          "verify": "蓝色连接线数量为1，state.firstFrameConnections长度为1",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 5,
          "action": "验证视频首帧图片显示",
          "mcp_tool": "mcp1_browser_evaluate",
          "mcp_params": {
            "function": "() => { const img = document.querySelector('.shot-frame-preview-image'); return { exists: !!img, display: img ? img.style.display : 'none', src: img ? img.src : '' }; }"
          },
          "verify": "视频首帧图片元素存在，display不为none，src有值",
          "pass": false,
          "remark": "",
          "is_processed": false
        }
      ],
      "is_processed": false
    },
