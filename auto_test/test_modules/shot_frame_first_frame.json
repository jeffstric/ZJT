          "expected_result": "分镜节点创建成功",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 3,
          "action": "从图片节点输出端口拖拽到分镜节点首帧端口",
          "mcp_tool": "mcp1_browser_drag",
          "mcp_params": {
            "startElement": "图片节点输出端口",
            "startRef": "<输出端口ref>",
            "endElement": "分镜节点首帧端口",
