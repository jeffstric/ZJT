{
  "id": "shot_frame_first_frame",
  "name": "分镜节点视频首帧模块",
  "description": "分镜节点视频首帧连接功能测试，包括蓝色连接线、磁吸效果、图片选择等",
  "features": [
    {
      "id": "first_frame_001",
      "name": "分镜节点视频首帧端口显示",
      "description": "验证分镜节点的视频首帧区域显示蓝色输入端口",
      "priority": "P0",
      "page_url": "/video-workflow",
      "pass": false,
      "remark": "",
      "test_steps": [
        {
          "step": 1,
          "action": "创建分镜节点",
          "mcp_tool": "mcp1_browser_click",
          "mcp_params": {
            "element": "添加分镜节点",
            "ref": "<添加分镜节点ref>"
          },
          "expected_result": "分镜节点创建成功",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 2,
          "action": "获取节点快照验证首帧端口",
          "mcp_tool": "mcp1_browser_snapshot",
          "mcp_params": {},
          "verify": "分镜节点包含视频首帧区域，左侧有蓝色输入端口(.first-frame-port)，端口样式为蓝色圆点",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 3,
          "action": "验证首帧端口样式",
          "mcp_tool": "mcp1_browser_evaluate",
          "mcp_params": {
            "function": "() => { const port = document.querySelector('.first-frame-port'); if(!port) return {exists: false}; const style = getComputedStyle(port); return { exists: true, background: style.backgroundColor, borderColor: style.borderColor }; }"
          },
          "verify": "端口存在且背景色为蓝色(#3b82f6)",
          "pass": false,
          "remark": "",
          "is_processed": false
        }
      ],
      "is_processed": false
    },
    {
      "id": "first_frame_002",
      "name": "图片节点连接到分镜节点首帧端口",
      "description": "验证用户可以从图片节点拖拽连接线到分镜节点的视频首帧端口，创建蓝色连接线",
      "priority": "P0",
      "page_url": "/video-workflow",
      "pass": false,
      "remark": "",
      "test_steps": [
        {
          "step": 1,
          "action": "创建图片节点并上传图片",
          "operation": "创建图片节点，上传测试图片",
          "expected_result": "图片节点创建成功，图片上传完成",
          "pass": false,
          "remark": "",
