{
  "module_name": "grid_image_generation",
  "description": "测试宫格图片生成功能",
  "tests": [
    {
      "test_name": "test_4_grid_generation",
      "description": "测试4宫格图片生成（2-5个分镜）",
      "steps": [
        {
          "action": "navigate",
          "url": "http://localhost:8000/video_workflow.html",
          "description": "打开视频工作流页面"
        },
        {
          "action": "wait",
          "selector": "#canvas",
          "description": "等待画布加载"
        },
        {
          "action": "click",
          "selector": "#menuAddScript",
          "description": "点击添加剧本节点"
        },
        {
          "action": "click",
          "selector": ".node .node-header",
          "description": "点击剧本节点标题栏展开编辑区"
        },
        {
          "action": "type",
          "selector": ".script-textarea",
          "text": "清晨，阳光洒在城市街道上。\n小明走进咖啡店，点了一杯拿铁。\n他坐在窗边，看着窗外的行人。\n咖啡的香气弥漫在空气中。",
          "description": "输入测试剧本（4个场景）"
        },
        {
          "action": "select",
          "selector": ".script-grid-model",
          "value": "gemini-2.5-pro-image-preview",
          "description": "选择标准版模型"
        },
        {
          "action": "click",
          "selector": ".script-split-grid-btn",
          "description": "点击宫格生图按钮"
        },
        {
          "action": "wait",
          "timeout": 5000,
          "description": "等待剧本解析"
        },
        {
          "action": "dialog_accept",
          "description": "确认生成对话框"
        },
        {
          "action": "wait",
          "selector": ".shot-frame-grid-status",
          "timeout": 10000,
          "description": "等待分镜图节点创建"
        },
        {
          "action": "assert",
          "selector": ".node[data-node-id]",
          "count": ">= 5",
          "description": "验证节点已创建（剧本+分镜组+分镜+分镜图）"
        },
        {
          "action": "assert",
          "selector": ".shot-frame-grid-status",
          "text_contains": "等待生成",
          "description": "验证分镜图节点状态"
        }
      ]
    },
    {
      "test_name": "test_9_grid_generation",
