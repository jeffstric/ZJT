{
  "id": "auth",
  "name": "用户认证模块",
  "description": "用户登录、登出功能的测试",
  "features": [
    {
      "id": "auth_001",
      "name": "用户登录功能",
      "description": "验证用户可以通过手机号和密码登录系统，登录成功后页面显示用户信息和算力值",
      "priority": "P0",
      "page_url": "/",
      "api_endpoint": "POST /api/auth/login",
      "pass": false,
      "remark": "",
      "test_steps": [
        {
          "step": 1,
          "action": "打开首页",
          "mcp_tool": "mcp1_browser_navigate",
          "mcp_params": {
            "url": "${config.base_url}/"
          },
          "expected_result": "首页正常加载",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 2,
          "action": "获取页面快照，查找登录按钮",
          "mcp_tool": "mcp1_browser_snapshot",
          "mcp_params": {},
          "verify": "页面快照中应包含「登录」按钮元素，记录其 ref 值",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 3,
          "action": "点击登录按钮",
          "mcp_tool": "mcp1_browser_click",
          "mcp_params": {
            "element": "登录按钮",
            "ref": "<从快照中获取的ref>"
          },
          "expected_result": "弹出登录模态框",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 4,
          "action": "获取模态框快照",
          "mcp_tool": "mcp1_browser_snapshot",
          "mcp_params": {},
          "verify": "模态框可见，包含手机号输入框、密码输入框、服务条款复选框、登录按钮",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 5,
          "action": "填写登录表单",
          "mcp_tool": "mcp1_browser_fill_form",
          "mcp_params": {
            "fields": [
              {
                "name": "手机号输入框",
                "type": "textbox",
                "ref": "<手机号输入框ref>",
                "value": "${config.credentials.phone}"
              },
              {
                "name": "密码输入框",
                "type": "textbox",
                "ref": "<密码输入框ref>",
                "value": "${config.credentials.password}"
              },
              {
                "name": "服务条款复选框",
                "type": "checkbox",
                "ref": "<复选框ref>",
                "value": "true"
              }
            ]
          },
          "expected_result": "表单字段正确填写",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 6,
          "action": "点击登录提交按钮",
          "mcp_tool": "mcp1_browser_click",
          "mcp_params": {
            "element": "登录提交按钮",
            "ref": "<登录按钮ref>"
          },
          "expected_result": "发起登录请求",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 7,
          "action": "等待登录完成",
          "mcp_tool": "mcp1_browser_wait_for",
          "mcp_params": {
            "text": "登出",
            "time": 5
          },
          "expected_result": "页面出现「登出」文字",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 8,
          "action": "验证登录成功-获取快照",
          "mcp_tool": "mcp1_browser_snapshot",
          "mcp_params": {},
          "verify": "页面右上角显示「登出」按钮，模态框已关闭",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 9,
          "action": "验证localStorage中的token",
          "mcp_tool": "mcp1_browser_evaluate",
          "mcp_params": {
            "function": "() => { return { auth_token: localStorage.getItem('auth_token'), user_id: localStorage.getItem('user_id') }; }"
          },
          "verify": "返回结果包含有效的 auth_token 和 user_id",
          "pass": false,
          "remark": "",
          "is_processed": false
        }
      ],
      "is_processed": false
    },
    {
      "id": "auth_002",
      "name": "用户登出功能",
      "description": "验证已登录用户可以成功登出，登出后页面恢复未登录状态",
      "priority": "P1",
      "page_url": "/",
      "api_endpoint": "POST /api/auth/logout",
      "pass": false,
      "remark": "",
      "prerequisites": [
        "auth_001"
      ],
      "test_steps": [
        {
          "step": 1,
          "action": "获取页面快照确认已登录",
          "mcp_tool": "mcp1_browser_snapshot",
          "mcp_params": {},
          "verify": "页面快照中应包含「登出」按钮元素",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 2,
          "action": "点击登出按钮",
          "mcp_tool": "mcp1_browser_click",
          "mcp_params": {
            "element": "登出按钮",
            "ref": "<登出按钮ref>"
          },
          "expected_result": "发起登出请求",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 3,
          "action": "等待页面状态更新",
          "mcp_tool": "mcp1_browser_wait_for",
          "mcp_params": {
            "text": "登录",
            "time": 3
          },
          "expected_result": "页面出现「登录」文字",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 4,
          "action": "获取快照验证登出成功",
          "mcp_tool": "mcp1_browser_snapshot",
          "mcp_params": {},
          "verify": "页面显示「登录」按钮，不显示「登出」按钮",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 5,
          "action": "验证localStorage已清除",
          "mcp_tool": "mcp1_browser_evaluate",
          "mcp_params": {
            "function": "() => { return { auth_token: localStorage.getItem('auth_token'), user_id: localStorage.getItem('user_id') }; }"
          },
          "verify": "auth_token 和 user_id 应为 null",
          "pass": false,
          "remark": "",
          "is_processed": false
        }
      ],
      "is_processed": false
    },
    {
      "id": "auth_003",
      "name": "未登录访问工作流列表",
      "description": "验证未登录用户访问工作流列表页时显示登录提示或跳转",
      "priority": "P1",
      "page_url": "/video-workflow-list",
      "pass": false,
      "remark": "",
      "test_steps": [
        {
          "step": 1,
          "action": "清除登录状态",
          "operation": "clear_storage",
          "expected_result": "localStorage 中 auth_token 和 user_id 被清除",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 2,
          "action": "访问工作流列表页",
          "operation": "navigate",
          "target_url": "/video-workflow-list",
          "expected_result": "页面显示需要登录的提示，或跳转到登录页",
          "pass": false,
          "remark": "",
          "is_processed": false
        }
      ],
      "is_processed": false
    },
    {
      "id": "auth_004",
      "name": "未登录访问工作流编辑器",
      "description": "验证未登录用户访问工作流编辑器时的处理",
      "priority": "P1",
      "page_url": "/video-workflow",
      "pass": false,
      "remark": "",
      "test_steps": [
        {
          "step": 1,
          "action": "清除登录状态",
          "mcp_tool": "mcp1_browser_evaluate",
          "mcp_params": {
            "function": "() => { localStorage.removeItem('auth_token'); localStorage.removeItem('user_id'); }"
          },
          "expected_result": "登录状态被清除",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 2,
          "action": "访问工作流编辑器页面",
          "mcp_tool": "mcp1_browser_navigate",
          "mcp_params": {
            "url": "${config.base_url}/video-workflow?id=1"
          },
          "expected_result": "页面正常加载（返回200状态码）",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 3,
          "action": "监听网络请求",
          "mcp_tool": "mcp1_browser_network_requests",
          "mcp_params": {
            "filter": "/api/video-workflow/"
          },
          "verify": "应捕获到 GET /api/video-workflow/1 请求返回 403 状态码",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 4,
          "action": "等待错误提示显示",
          "mcp_tool": "mcp1_browser_wait_for",
          "mcp_params": {
            "text": "无权限访问该工作流",
            "time": 5
          },
          "expected_result": "页面显示权限错误提示",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 5,
          "action": "获取页面快照验证错误提示",
          "mcp_tool": "mcp1_browser_snapshot",
          "mcp_params": {},
          "verify": "页面应显示「无权限访问该工作流」错误提示（通过toast或其他方式）",
          "pass": false,
          "remark": "",
          "is_processed": false
        }
      ],
      "is_processed": false
    },
    {
      "id": "auth_005",
      "name": "登录态缺失user_id访问工作流列表",
      "description": "回归用例：当 auth_token 存在但 localStorage.user_id 缺失时访问工作流列表页，不应触发 /api/video-workflow/list 导致 400，应提示用户先登录",
      "priority": "P0",
      "page_url": "/video-workflow-list",
      "pass": false,
      "remark": "",
      "test_steps": [
        {
          "step": 1,
          "action": "清除 user_id 但保留 auth_token（模拟异常登录态）",
          "operation": "set_storage",
          "key": "auth_token",
          "value": "{auth_token}",
          "expected_result": "localStorage.auth_token 被设置，user_id 为空",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 2,
          "action": "清除 user_id",
          "operation": "set_storage",
          "key": "user_id",
          "value": "",
          "expected_result": "localStorage.user_id 为空字符串或 null",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 3,
          "action": "访问工作流列表页",
          "mcp_tool": "mcp1_browser_navigate",
          "mcp_params": {
            "url": "${config.base_url}/video-workflow-list"
          },
          "expected_result": "页面显示「请先登录」提示，并提供「去登录」入口",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 4,
          "action": "获取页面快照验证登录提示",
          "mcp_tool": "mcp1_browser_snapshot",
          "mcp_params": {},
          "verify": "页面包含「请先登录」文字，且不应渲染工作流卡片列表",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 5,
          "action": "检查网络请求不应出现 400",
          "mcp_tool": "mcp1_browser_network_requests",
          "mcp_params": {},
          "verify": "不应出现 GET /api/video-workflow/list 返回 400 (user_id is required) 的请求；最好不发起该请求",
          "pass": false,
          "remark": "",
          "is_processed": false
        }
      ],
      "is_processed": false
    }
  ]
}