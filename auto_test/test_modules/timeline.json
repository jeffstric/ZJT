    {
      "id": "timeline_006",
      "name": "拖拽替换视频",
      "description": "验证按住Shift键拖拽可以替换视频，被拖拽的视频从时间轴删除",
      "priority": "P0",
      "page_url": "/video-workflow",
      "pass": false,
      "remark": "",
      "test_steps": [
        {
          "step": 1,
          "action": "添加3个视频到时间轴",
          "operation": "添加视频A、B、C",
          "expected_result": "时间轴显示 A B C",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 2,
          "action": "按住Shift拖拽A到B上",
          "mcp_tool": "mcp1_browser_evaluate",
          "mcp_params": {
            "function": "() => { const clipA = document.querySelector('.timeline-clip:nth-child(1)'); const clipB = document.querySelector('.timeline-clip:nth-child(2)'); const dragEvent = new DragEvent('dragstart', { dataTransfer: new DataTransfer(), shiftKey: false }); clipA.dispatchEvent(dragEvent); const overEvent = new DragEvent('dragover', { dataTransfer: dragEvent.dataTransfer, shiftKey: true }); clipB.dispatchEvent(overEvent); return clipB.classList.contains('drop-target'); }"
          },
          "verify": "目标片段B显示高亮（drop-target类）",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 3,
          "action": "释放鼠标完成替换",
          "operation": "模拟drop事件",
          "expected_result": "B的内容变为A的内容，A从时间轴删除",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 4,
          "action": "验证替换后状态",
          "mcp_tool": "mcp1_browser_evaluate",
          "mcp_params": {
            "function": "() => { const clips = Array.from(document.querySelectorAll('.timeline-clip')); return { count: clips.length, names: clips.map(c => c.querySelector('.timeline-clip-name').textContent) }; }"
          },
          "verify": "片段数量为2，顺序为 B(A的内容) C",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 5,
          "action": "验证总时长更新",
          "mcp_tool": "mcp1_browser_snapshot",
          "mcp_params": {},
          "verify": "总时长减少了被删除视频的时长",
          "pass": false,
          "remark": "",
          "is_processed": false
        }
      ],
      "is_processed": false
    },
