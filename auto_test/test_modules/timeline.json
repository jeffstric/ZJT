{
  "id": "timeline",
  "name": "视频时间轴模块",
  "description": "视频时间轴功能的测试，包括添加视频、拖拽排序、拖拽替换、删除片段等操作",
  "features": [
    {
      "id": "timeline_001",
      "name": "时间轴面板显示",
      "description": "验证添加视频到时间轴后，时间轴面板正确显示在页面底部",
      "priority": "P0",
      "page_url": "/video-workflow",
      "pass": false,
      "remark": "",
      "prerequisites": [
        "editor_009"
      ],
      "test_steps": [
        {
          "step": 1,
          "action": "创建视频节点并上传视频",
          "mcp_tool": "mcp1_browser_file_upload",
          "mcp_params": {
            "paths": [
              "${config.test_video_path}"
            ]
          },
          "expected_result": "视频上传成功，节点显示视频预览",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 2,
          "action": "获取快照找到添加到时间轴按钮",
          "mcp_tool": "mcp1_browser_snapshot",
          "mcp_params": {},
          "verify": "视频节点包含「添加到时间轴」按钮，记录其 ref",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 3,
          "action": "点击添加到时间轴按钮",
          "mcp_tool": "mcp1_browser_click",
          "mcp_params": {
            "element": "添加到时间轴按钮",
            "ref": "<添加到时间轴按钮ref>"
          },
          "expected_result": "视频添加到时间轴",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 4,
          "action": "等待时间轴显示",
          "mcp_tool": "mcp1_browser_wait_for",
          "mcp_params": {
            "text": "时间轴",
            "time": 3
          },
          "expected_result": "时间轴面板出现",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 5,
          "action": "获取时间轴快照验证结构",
          "mcp_tool": "mcp1_browser_snapshot",
          "mcp_params": {},
          "verify": "时间轴面板包含：标题「时间轴」、总时长显示、操作提示「拖拽调整顺序 | 按住Shift拖拽可替换」、清空按钮、收起按钮、时间刻度尺、视频轨道、视频片段",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 6,
          "action": "验证画布容器添加padding",
          "mcp_tool": "mcp1_browser_evaluate",
          "mcp_params": {
            "function": "() => { const canvas = document.getElementById('canvasContainer'); return canvas.classList.contains('timeline-visible'); }"
          },
          "verify": "画布容器包含 timeline-visible 类",
          "pass": false,
          "remark": "",
          "is_processed": false
        }
      ],
      "is_processed": false
    },
    {
      "id": "timeline_002",
      "name": "视频时长自动获取",
      "description": "验证添加视频到时间轴时，系统自动获取视频时长并正确显示",
      "priority": "P0",
      "page_url": "/video-workflow",
      "pass": false,
      "remark": "",
      "test_steps": [
        {
          "step": 1,
          "action": "添加视频到时间轴",
          "operation": "按 timeline_001 的步骤添加视频",
          "expected_result": "视频添加成功",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 2,
          "action": "检查视频片段宽度",
          "mcp_tool": "mcp1_browser_evaluate",
          "mcp_params": {
            "function": "() => { const clip = document.querySelector('.timeline-clip'); if (!clip) return null; const width = parseInt(clip.style.width); const duration = parseInt(clip.querySelector('.timeline-clip-duration').textContent); return { width, duration, ratio: width / duration }; }"
          },
          "verify": "视频片段宽度 = 时长 × 10px，比例为 10",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 3,
          "action": "检查时间轴总时长",
          "mcp_tool": "mcp1_browser_snapshot",
          "mcp_params": {},
          "verify": "总时长显示格式为「总时长: M:SS」，数值与视频实际时长一致",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 4,
          "action": "检查时间刻度",
          "mcp_tool": "mcp1_browser_evaluate",
          "mcp_params": {
            "function": "() => { const marks = document.querySelectorAll('.ruler-mark'); return Array.from(marks).map(m => m.textContent); }"
          },
          "verify": "时间刻度按5秒或10秒间隔显示（根据总时长）",
          "pass": false,
          "remark": "",
          "is_processed": false
        }
      ],
      "is_processed": false
    },
