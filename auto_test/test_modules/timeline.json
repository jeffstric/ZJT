    },
    {
      "id": "timeline_004",
      "name": "视频片段位置对齐时间刻度",
      "description": "验证视频片段的末尾位置对应累计播放时间刻度",
      "priority": "P0",
      "page_url": "/video-workflow",
      "pass": false,
      "remark": "",
      "test_steps": [
        {
          "step": 1,
          "action": "添加多个不同时长的视频",
          "operation": "添加3个视频，时长分别为5秒、10秒、8秒",
          "expected_result": "3个视频都添加到时间轴",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 2,
          "action": "检查片段位置",
          "mcp_tool": "mcp1_browser_evaluate",
          "mcp_params": {
            "function": "() => { const clips = Array.from(document.querySelectorAll('.timeline-clip')); return clips.map(c => ({ left: parseInt(c.style.left), width: parseInt(c.style.width), duration: parseInt(c.querySelector('.timeline-clip-duration').textContent) })); }"
          },
          "verify": "第1个片段 left=0, 第2个片段 left=第1个的时长×10, 第3个片段 left=(第1个+第2个)的时长×10",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 3,
          "action": "验证片段末尾对齐刻度",
          "operation": "计算每个片段的 left + width",
          "verify": "片段1末尾=5秒刻度(50px), 片段2末尾=15秒刻度(150px), 片段3末尾=23秒刻度(230px)",
          "pass": false,
          "remark": "",
          "is_processed": false
        }
      ],
      "is_processed": false
    },
