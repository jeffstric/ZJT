          },
          "expected_result": "拖拽过程中显示蓝色插入指示器",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 3,
          "action": "验证拖拽后顺序",
          "mcp_tool": "mcp1_browser_evaluate",
          "mcp_params": {
            "function": "() => { const clips = Array.from(document.querySelectorAll('.timeline-clip')); return clips.map(c => c.querySelector('.timeline-clip-name').textContent); }"
          },
          "verify": "顺序变为 B A C",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 4,
          "action": "验证片段位置重新计算",
          "mcp_tool": "mcp1_browser_evaluate",
          "mcp_params": {
            "function": "() => { const clips = Array.from(document.querySelectorAll('.timeline-clip')); return clips.map(c => parseInt(c.style.left)); }"
          },
          "verify": "每个片段的 left 值根据新顺序重新计算",
          "pass": false,
          "remark": "",
          "is_processed": false
        }
      ],
      "is_processed": false
