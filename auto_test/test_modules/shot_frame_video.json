          },
          "expected_result": "抽卡次数设置为3",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 4,
          "action": "点击生成视频按钮",
          "mcp_tool": "mcp1_browser_click",
          "mcp_params": {
            "element": "生成视频按钮",
            "ref": ".node[data-node-id] .shot-frame-generate-video-btn"
          },
          "expected_result": "开始生成视频",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 5,
          "action": "验证API请求中的count参数",
          "mcp_tool": "mcp1_browser_network_requests",
