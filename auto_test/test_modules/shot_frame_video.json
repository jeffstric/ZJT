      "pass": false,
      "remark": "",
      "test_steps": [
        {
          "step": 1,
          "action": "创建分镜组节点并生成分镜图",
          "operation": "创建分镜组节点，填写图片提示词，点击生成分镜图按钮",
          "expected_result": "分镜图生成成功，预览图显示",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 2,
          "action": "验证分镜图预览显示",
          "mcp_tool": "mcp1_browser_snapshot",
          "mcp_params": {},
