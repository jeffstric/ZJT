            "text": "1"
          },
          "expected_result": "抽卡次数设置为1",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 6,
          "action": "点击生成视频按钮",
          "mcp_tool": "mcp1_browser_click",
          "mcp_params": {
            "element": "生成视频按钮",
            "ref": "<生成视频按钮ref>"
          },
          "expected_result": "按钮变为生成中状态",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 7,
          "action": "验证API请求发送",
          "mcp_tool": "mcp1_browser_network_requests",
          "mcp_params": {},
          "verify": "存在POST /api/ai-app-run-image-url请求，包含image_url、prompt、duration_seconds、count、ratio参数",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 8,
          "action": "等待视频生成完成",
          "mcp_tool": "mcp1_browser_wait_for",
          "mcp_params": {
            "text": "生成视频",
            "time": 180
          },
          "expected_result": "按钮恢复为生成视频状态",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 9,
          "action": "验证视频节点自动创建",
          "mcp_tool": "mcp1_browser_evaluate",
          "mcp_params": {
            "function": "() => { const s = window.state; if(!s || !Array.isArray(s.nodes)) return { count: 0 }; return { count: s.nodes.filter(n => n.type === 'video').length }; }"
          },
          "verify": "视频节点数量 >= 1",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 10,
          "action": "验证视频节点连接关系",
          "mcp_tool": "mcp1_browser_evaluate",
          "mcp_params": {
            "function": "() => { const s = window.state; if(!s) return { hasConn: false }; const shotNode = s.nodes.find(n => n.type === 'shot_group'); const videoNode = s.nodes.find(n => n.type === 'video'); if(!shotNode || !videoNode) return { hasConn: false }; return { hasConn: s.connections.some(c => c.from === shotNode.id && c.to === videoNode.id) }; }"
          },
          "verify": "分镜节点和视频节点之间存在连接线",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 11,
          "action": "验证视频预览显示",
          "mcp_tool": "mcp1_browser_snapshot",
          "mcp_params": {},
          "verify": "视频节点包含视频预览区域，视频缩略图可见",
          "pass": false,
          "remark": "",
          "is_processed": false
        }
      ],
      "is_processed": false
