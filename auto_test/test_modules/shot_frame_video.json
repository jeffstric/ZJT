          "remark": "",
          "is_processed": false
        },
        {
          "step": 6,
          "action": "等待视频生成完成",
          "mcp_tool": "mcp1_browser_wait_for",
          "mcp_params": {
            "text": "生成视频",
            "time": 180
          },
          "expected_result": "按钮恢复为生成视频状态",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 7,
          "action": "验证创建了3个视频节点",
          "mcp_tool": "mcp1_browser_evaluate",
          "mcp_params": {
            "function": "() => { const s = window.state; if(!s || !Array.isArray(s.nodes)) return { count: 0 }; return { count: s.nodes.filter(n => n.type === 'video').length }; }"
          },
          "verify": "视频节点数量为3",
          "pass": false,
          "remark": "",
          "is_processed": false
        }
      ],
      "is_processed": false
    },
    {
      "id": "shot_video_003",
      "name": "分镜视频生成-错误处理测试",
      "description": "验证未生成分镜图时点击生成视频按钮的错误提示",
      "priority": "P1",
      "page_url": "/video-workflow",
      "pass": false,
      "remark": "",
