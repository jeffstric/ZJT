        {
          "step": 4,
          "action": "验证搜索结果",
          "mcp_tool": "mcp1_browser_evaluate",
          "mcp_params": {
            "function": "() => { const cards = document.querySelectorAll('.workflow-card'); const names = []; cards.forEach(card => { const nameEl = card.querySelector('.workflow-name'); if (nameEl) names.push(nameEl.textContent.trim()); }); return { cardCount: cards.length, names: names, hasTestKeyword: names.some(name => name.includes('测试')) }; }"
          },
          "verify": "返回结果显示工作流名称包含「测试」关键词",
          "expected_result": "列表只显示名称包含「测试」的工作流",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 5,
          "action": "清空搜索框",
          "mcp_tool": "mcp1_browser_clear",
          "mcp_params": {
            "element": "搜索框",
            "ref": "<搜索框ref>"
          },
          "expected_result": "搜索框内容被清空",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 6,
          "action": "等待列表恢复",
