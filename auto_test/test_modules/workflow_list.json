  "features": [
    {
      "id": "list_001",
      "name": "访问工作流列表页",
      "description": "验证用户可以正常访问工作流列表页面，页面正确加载并显示工作流卡片列表",
      "priority": "P0",
      "page_url": "/video-workflow-list",
      "api_endpoint": "GET /api/video-workflow/list",
      "pass": false,
      "remark": "",
      "test_steps": [
        {
          "step": 1,
          "action": "导航到工作流列表页",
          "mcp_tool": "mcp1_browser_navigate",
          "mcp_params": {
            "url": "${config.base_url}/video-workflow-list"
          },
          "expected_result": "页面正常加载",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 2,
          "action": "等待页面加载完成",
          "mcp_tool": "mcp1_browser_wait_for",
          "mcp_params": {
            "text": "视频工作流",
            "time": 5
          },
          "expected_result": "页面标题出现",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 3,
          "action": "获取页面快照验证结构",
          "mcp_tool": "mcp1_browser_snapshot",
          "mcp_params": {},
          "verify": "页面包含：品牌Logo、「视频工作流」标题、「新建工作流」按钮、搜索框、状态筛选下拉框、工作流卡片列表或空状态提示",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 4,
          "action": "检查网络请求",
          "mcp_tool": "mcp1_browser_network_requests",
          "mcp_params": {},
          "verify": "存在 GET /api/video-workflow/list 请求且返回成功",
          "pass": false,
          "remark": "",
          "is_processed": false
        }
      ],
      "is_processed": false
    },
    {
      "id": "list_002",
      "name": "工作流卡片展示",
      "description": "验证每个工作流卡片正确显示名称、描述、状态标签、创建时间、编辑和删除按钮",
      "priority": "P0",
      "page_url": "/video-workflow-list",
      "pass": false,
      "remark": "",
      "prerequisites": [
        "list_001"
      ],
      "test_steps": [
        {
          "step": 1,
          "action": "获取页面快照检查卡片元素",
          "mcp_tool": "mcp1_browser_snapshot",
          "mcp_params": {},
          "verify": "每个工作流卡片包含：封面图区域(.workflow-cover)、名称(.workflow-name)、描述(.workflow-desc)、状态标签(.workflow-status)、创建时间(.workflow-meta)",
          "expected_result": "每个卡片包含封面图区域、名称、描述、状态标签、创建时间",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 2,
          "action": "检查状态标签样式",
          "mcp_tool": "mcp1_browser_evaluate",
          "mcp_params": {
            "function": "() => { const statusElements = document.querySelectorAll('.workflow-status'); const styles = []; statusElements.forEach(el => { const classList = Array.from(el.classList); styles.push({ text: el.textContent.trim(), classes: classList }); }); return styles; }"
          },
          "verify": "返回的状态标签应包含正确的CSS类：启用状态(.status-enabled)、禁用状态(.status-disabled)、草稿状态(.status-draft)",
          "expected_result": "启用状态显示绿色(.status-enabled)，禁用状态显示红色(.status-disabled)，草稿状态显示黄色(.status-draft)",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 3,
          "action": "检查操作按钮",
          "mcp_tool": "mcp1_browser_evaluate",
          "mcp_params": {
            "function": "() => { const cards = document.querySelectorAll('.workflow-card'); const buttonInfo = []; cards.forEach((card, index) => { const actions = card.querySelector('.workflow-actions'); const buttons = actions?.querySelectorAll('button, .btn'); let editBtn = null; let deleteBtn = null; buttons?.forEach(btn => { const text = btn.textContent?.trim(); if (text?.includes('编辑')) editBtn = btn; if (text?.includes('删除')) deleteBtn = btn; }); buttonInfo.push({ cardIndex: index, hasEditBtn: !!editBtn, hasDeleteBtn: !!deleteBtn, editBtnText: editBtn?.textContent?.trim(), deleteBtnText: deleteBtn?.textContent?.trim() }); }); return buttonInfo; }"
          },
          "verify": "每个工作流卡片底部应有「编辑」和「删除」两个按钮",
          "expected_result": "每个卡片底部有「编辑」和「删除」两个按钮",
          "pass": false,
          "remark": "",
          "is_processed": false
        }
      ],
      "is_processed": false
    },
    {
