{
  "id": "error_handling",
  "name": "错误处理与边界场景",
  "description": "验证系统对各种错误情况和边界场景的处理能力",
  "features": [
    {
      "id": "error_001",
      "name": "未登录访问工作流列表",
      "description": "验证未登录用户访问工作流列表页时显示登录提示或跳转",
      "priority": "P1",
      "page_url": "/video-workflow-list",
      "pass": false,
      "remark": "",
      "test_steps": [
        {
          "step": 1,
          "action": "清除登录状态",
          "operation": "clear_storage",
          "expected_result": "localStorage 中 auth_token 和 user_id 被清除",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 2,
          "action": "访问工作流列表页",
          "operation": "navigate",
          "target_url": "/video-workflow-list",
          "expected_result": "页面显示需要登录的提示，或跳转到登录页",
          "pass": false,
          "remark": "",
          "is_processed": false
        }
      ],
      "is_processed": false
    },
    {
      "id": "error_011",
      "name": "登录态缺失user_id访问工作流列表",
      "description": "回归用例：当 auth_token 存在但 localStorage.user_id 缺失时访问工作流列表页，不应触发 /api/video-workflow/list 导致 400，应提示用户先登录",
      "priority": "P0",
      "page_url": "/video-workflow-list",
      "pass": false,
      "remark": "",
      "test_steps": [
        {
          "step": 1,
          "action": "清除 user_id 但保留 auth_token（模拟异常登录态）",
          "operation": "set_storage",
          "key": "auth_token",
          "value": "{auth_token}",
          "expected_result": "localStorage.auth_token 被设置，user_id 为空",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 2,
          "action": "清除 user_id",
          "operation": "set_storage",
          "key": "user_id",
          "value": "",
          "expected_result": "localStorage.user_id 为空字符串或 null",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 3,
          "action": "访问工作流列表页",
          "mcp_tool": "mcp1_browser_navigate",
          "mcp_params": {
            "url": "${config.base_url}/video-workflow-list"
          },
          "expected_result": "页面显示「请先登录」提示，并提供「去登录」入口",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 4,
          "action": "获取页面快照验证登录提示",
          "mcp_tool": "mcp1_browser_snapshot",
          "mcp_params": {},
          "verify": "页面包含「请先登录」文字，且不应渲染工作流卡片列表",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 5,
          "action": "检查网络请求不应出现 400",
          "mcp_tool": "mcp1_browser_network_requests",
          "mcp_params": {},
          "verify": "不应出现 GET /api/video-workflow/list 返回 400 (user_id is required) 的请求；最好不发起该请求",
          "pass": false,
          "remark": "",
          "is_processed": false
        }
      ],
      "is_processed": false
    },
    {
      "id": "error_002",
      "name": "未登录访问工作流编辑器",
      "description": "验证未登录用户访问工作流编辑器时的处理",
      "priority": "P1",
      "page_url": "/video-workflow",
      "pass": false,
      "remark": "",
      "test_steps": [
        {
          "step": 1,
          "action": "清除登录状态",
          "operation": "clear_storage",
          "expected_result": "登录状态被清除",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 2,
          "action": "访问工作流编辑器",
          "operation": "navigate",
          "target_url": "/video-workflow?id=1",
          "expected_result": "提示需要登录或跳转到登录页",
          "pass": false,
          "remark": "",
          "is_processed": false
        }
      ],
      "is_processed": false
    },
    {
      "id": "error_003",
      "name": "访问不存在的工作流",
      "description": "验证用户访问不存在的工作流ID时显示适当错误提示",
      "priority": "P1",
      "page_url": "/video-workflow?id=99999",
      "pass": false,
      "remark": "",
      "test_steps": [
        {
          "step": 1,
          "action": "访问不存在的工作流",
          "operation": "navigate",
          "target_url": "/video-workflow?id=99999",
          "expected_result": "显示错误提示「工作流不存在」或跳转到列表页",
          "pass": false,
          "remark": "",
          "is_processed": false
        }
      ],
      "is_processed": false
    },
    {
      "id": "error_004",
      "name": "上传无效文件类型",
      "description": "验证用户上传非图片/视频文件时显示错误提示",
      "priority": "P2",
      "page_url": "/video-workflow",
      "pass": false,
      "remark": "",
      "test_steps": [
        {
          "step": 1,
          "action": "尝试上传txt文件",
          "operation": "upload",
          "selector": ".start-file",
          "test_file": "test.txt",
          "expected_result": "显示错误提示，文件未被接受",
          "pass": false,
          "remark": "",
          "is_processed": false
        }
      ],
      "is_processed": false
    },
    {
      "id": "error_005",
      "name": "网络错误处理",
      "description": "验证网络请求失败时显示适当的错误提示",
      "priority": "P2",
      "page_url": "/video-workflow",
      "pass": false,
      "remark": "",
      "test_steps": [
        {
          "step": 1,
          "action": "模拟网络断开",
          "operation": "network_offline",
          "expected_result": "网络状态变为离线",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 2,
          "action": "尝试保存工作流",
          "operation": "click",
          "selector": "#saveBtn",
          "expected_result": "显示网络错误提示 Toast",
          "pass": false,
          "remark": "",
          "is_processed": false
        }
      ],
      "is_processed": false
    },
    {
      "id": "error_006",
      "name": "工作流名称为空验证",
      "description": "验证创建工作流时名称为空显示验证错误",
      "priority": "P1",
      "page_url": "/video-workflow-list",
      "pass": false,
      "remark": "",
      "test_steps": [
        {
          "step": 1,
          "action": "点击新建工作流",
          "operation": "click",
          "selector": "button:has-text('新建工作流')",
          "expected_result": "弹出模态框",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 2,
          "action": "不输入名称直接点击保存",
          "operation": "click",
          "selector": "#createModal button:has-text('保存')",
          "expected_result": "显示验证错误「请输入工作流名称」，不发起API请求",
          "pass": false,
          "remark": "",
          "is_processed": false
        }
      ],
      "is_processed": false
    },
    {
      "id": "error_007",
      "name": "删除确认取消",
      "description": "验证用户在删除确认框点击取消时不执行删除操作",
      "priority": "P1",
      "page_url": "/video-workflow-list",
      "pass": false,
      "remark": "",
      "test_steps": [
        {
          "step": 1,
          "action": "点击删除按钮",
          "operation": "click",
          "selector": ".workflow-card .btn-danger:has-text('删除')",
          "expected_result": "弹出删除确认框",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 2,
          "action": "点击取消按钮",
          "operation": "click",
          "selector": "#deleteModal .btn-secondary:has-text('取消')",
          "expected_result": "模态框关闭，工作流未被删除",
          "pass": false,
          "remark": "",
          "is_processed": false
        }
      ],
      "is_processed": false
    },
    {
      "id": "error_008",
      "name": "视频生成超时处理",
      "description": "验证视频生成轮询超时后显示适当提示",
      "priority": "P2",
      "page_url": "/video-workflow",
      "pass": false,
      "remark": "",
      "test_steps": [
        {
          "step": 1,
          "action": "触发视频生成",
          "operation": "trigger_generate",
          "expected_result": "开始轮询视频状态",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 2,
          "action": "等待轮询超时",
          "operation": "wait",
          "wait_time_ms": 300000,
          "expected_result": "超时后显示错误提示，按钮恢复可点击状态",
          "pass": false,
          "remark": "",
          "is_processed": false
        }
      ],
      "is_processed": false
    },
    {
      "id": "error_009",
      "name": "Token过期处理",
      "description": "验证用户Token过期后请求返回401时的处理",
      "priority": "P1",
      "pass": false,
      "remark": "",
      "test_steps": [
        {
          "step": 1,
          "action": "设置过期Token",
          "operation": "set_storage",
          "key": "auth_token",
          "value": "expired_token",
          "expected_result": "Token被设置为过期值",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 2,
          "action": "发起API请求",
          "operation": "navigate",
          "target_url": "/video-workflow-list",
          "expected_result": "API返回401，提示用户重新登录",
          "pass": false,
          "remark": "",
          "is_processed": false
        }
      ],
      "is_processed": false
    },
    {
      "id": "error_010",
      "name": "模态框外点击关闭",
      "description": "验证点击模态框外部区域可以关闭模态框",
      "priority": "P2",
      "page_url": "/video-workflow-list",
      "pass": false,
      "remark": "",
      "test_steps": [
        {
          "step": 1,
          "action": "打开新建模态框",
          "operation": "click",
          "selector": "button:has-text('新建工作流')",
          "expected_result": "模态框可见",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 2,
          "action": "点击模态框遮罩层",
          "operation": "click",
          "selector": ".modal-overlay",
          "expected_result": "模态框关闭",
          "pass": false,
          "remark": "",
          "is_processed": false
        }
      ],
      "is_processed": false
    }
  ]
}