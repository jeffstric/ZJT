{
  "id": "error_handling",
  "name": "错误处理与边界场景",
  "description": "验证系统对各种错误情况和边界场景的处理能力",
  "features": [
    {
      "id": "error_003",
      "name": "访问不存在的工作流",
      "description": "验证用户访问不存在的工作流ID时显示适当错误提示",
      "priority": "P1",
      "page_url": "/video-workflow?id=99999",
      "pass": false,
      "remark": "",
      "test_steps": [
        {
          "step": 1,
          "action": "访问不存在的工作流",
          "operation": "navigate",
          "target_url": "/video-workflow?id=99999",
          "expected_result": "显示错误提示「工作流不存在」或跳转到列表页",
          "pass": false,
          "remark": "",
          "is_processed": false
        }
      ],
      "is_processed": false
    },
    {
      "id": "error_004",
      "name": "上传无效文件类型",
      "description": "验证用户上传非图片/视频文件时显示错误提示",
      "priority": "P2",
      "page_url": "/video-workflow",
      "pass": false,
      "remark": "",
      "test_steps": [
        {
          "step": 1,
          "action": "尝试上传txt文件",
          "operation": "upload",
          "selector": ".start-file",
          "test_file": "test.txt",
          "expected_result": "显示错误提示，文件未被接受",
          "pass": false,
          "remark": "",
          "is_processed": false
        }
      ],
      "is_processed": false
    },
    {
      "id": "error_005",
      "name": "网络错误处理",
      "description": "验证网络请求失败时显示适当的错误提示",
      "priority": "P2",
      "page_url": "/video-workflow",
      "pass": false,
      "remark": "",
      "test_steps": [
        {
          "step": 1,
          "action": "模拟网络断开",
          "operation": "network_offline",
          "expected_result": "网络状态变为离线",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 2,
          "action": "尝试保存工作流",
          "operation": "click",
          "selector": "#saveBtn",
          "expected_result": "显示网络错误提示 Toast",
          "pass": false,
          "remark": "",
          "is_processed": false
        }
      ],
      "is_processed": false
    },
    {
      "id": "error_008",
      "name": "视频生成超时处理",
      "description": "验证视频生成轮询超时后显示适当提示",
      "priority": "P2",
      "page_url": "/video-workflow",
      "pass": false,
      "remark": "",
      "test_steps": [
        {
          "step": 1,
          "action": "触发视频生成",
          "operation": "trigger_generate",
          "expected_result": "开始轮询视频状态",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 2,
          "action": "等待轮询超时",
          "operation": "wait",
          "wait_time_ms": 300000,
          "expected_result": "超时后显示错误提示，按钮恢复可点击状态",
          "pass": false,
          "remark": "",
          "is_processed": false
        }
      ],
      "is_processed": false
    },
    {
      "id": "error_009",
      "name": "Token过期处理",
      "description": "验证用户Token过期后请求返回401时的处理",
      "priority": "P1",
      "pass": false,
      "remark": "",
      "test_steps": [
        {
          "step": 1,
          "action": "设置过期Token",
          "operation": "set_storage",
          "key": "auth_token",
          "value": "expired_token",
          "expected_result": "Token被设置为过期值",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 2,
          "action": "发起API请求",
          "operation": "navigate",
          "target_url": "/video-workflow-list",
          "expected_result": "API返回401，提示用户重新登录",
          "pass": false,
          "remark": "",
          "is_processed": false
        }
      ],
      "is_processed": false
    },
    {
      "id": "error_010",
      "name": "模态框外点击关闭",
      "description": "验证点击模态框外部区域可以关闭模态框",
      "priority": "P2",
      "page_url": "/video-workflow-list",
      "pass": false,
      "remark": "",
      "test_steps": [
        {
          "step": 1,
          "action": "打开新建模态框",
          "operation": "click",
          "selector": "button:has-text('新建工作流')",
          "expected_result": "模态框可见",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 2,
          "action": "点击模态框遮罩层",
          "operation": "click",
          "selector": ".modal-overlay",
          "expected_result": "模态框关闭",
          "pass": false,
          "remark": "",
          "is_processed": false
        }
      ],
      "is_processed": false
    },
    {
      "id": "error_011",
      "name": "算力查询认证失败自动跳转登录",
      "description": "验证工作流页面算力查询API返回400/401/403时自动跳转到登录页，并在登录后自动返回",
      "priority": "P1",
      "pass": false,
      "remark": "",
      "test_steps": [
        {
          "step": 1,
          "action": "设置无效Token",
          "operation": "set_storage",
          "key": "auth_token",
          "value": "invalid_token_12345",
          "expected_result": "Token被设置为无效值",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 2,
          "action": "访问工作流编辑页",
          "operation": "navigate",
          "target_url": "/video-workflow?id=1",
          "expected_result": "页面加载，算力查询API返回认证失败",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 3,
          "action": "等待自动跳转",
          "operation": "wait",
          "wait_time_ms": 3000,
          "expected_result": "自动跳转到 /index.html 登录页",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 4,
          "action": "验证URL包含登录页",
          "operation": "check_url",
          "expected_url": "/index.html",
          "expected_result": "当前URL为登录页",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 5,
          "action": "验证localStorage保存了返回地址",
          "operation": "check_storage",
          "key": "redirect_after_login",
          "expected_result": "localStorage中保存了工作流页面URL",
          "pass": false,
          "remark": "",
          "is_processed": false
        }
      ],
      "is_processed": false
    }
  ]
}