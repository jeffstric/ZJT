{
  "id": "node_operations",
  "name": "节点操作模块",
  "description": "各类节点的具体操作功能测试，包括图片上传、参数设置、视频生成等",
  "features": [
    {
      "id": "node_001",
      "name": "图生视频节点-上传首帧图片",
      "description": "验证用户可以在图生视频节点上传首帧图片，图片上传到服务器后显示预览",
      "priority": "P0",
      "page_url": "/video-workflow",
      "api_endpoint": "POST /api/video-workflow/upload",
      "pass": false,
      "remark": "",
      "test_steps": [
        {
          "step": 1,
          "action": "获取节点快照找到文件输入",
          "mcp_tool": "mcp1_browser_snapshot",
          "mcp_params": {},
          "verify": "图生视频节点中包含首帧画面文件输入区域",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 2,
          "action": "点击首帧画面文件输入触发文件选择",
          "mcp_tool": "mcp1_browser_click",
          "mcp_params": {
            "element": "首帧画面文件输入",
            "ref": "<文件输入ref>"
          },
          "expected_result": "触发文件选择器",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 3,
          "action": "上传测试图片文件",
          "mcp_tool": "mcp1_browser_file_upload",
          "mcp_params": {
            "paths": [
              "${config.test_assets.test_image}"
            ]
          },
          "expected_result": "文件开始上传",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 4,
          "action": "等待上传完成",
          "mcp_tool": "mcp1_browser_wait_for",
          "mcp_params": {
            "text": "首帧图片上传成功",
            "time": 10
          },
          "expected_result": "Toast提示出现",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 5,
          "action": "获取快照验证预览",
          "mcp_tool": "mcp1_browser_snapshot",
          "mcp_params": {},
          "verify": "首帧预览区域可见，显示图片缩略图和「清除」按钮",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 6,
          "action": "检查上传API请求",
          "mcp_tool": "mcp1_browser_network_requests",
          "mcp_params": {},
          "verify": "存在 POST /api/video-workflow/upload 请求且返回成功",
          "pass": false,
          "remark": "",
          "is_processed": false
        }
      ],
      "is_processed": false
    },
