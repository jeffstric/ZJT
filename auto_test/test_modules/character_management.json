          "remark": "",
          "is_processed": false
        },
        {
          "step": 6,
          "action": "验证角色卡ID从数据库加载成功",
          "mcp_tool": "mcp1_browser_evaluate",
          "mcp_params": {
            "function": "() => { const node = window.state.nodes.find(n => n.type === 'character'); return { hasSoraCharacter: !!node?.data?.sora_character, buttonText: document.querySelector('.character-create-card-btn')?.textContent }; }"
          },
          "verify": "sora_character字段存在，按钮显示'重新生成sora角色卡'",
          "pass": false,
          "remark": "",
          "is_processed": false
        }
      ],
      "is_processed": false
