{
  "id": "character_management",
  "name": "角色管理模块",
  "description": "工作流编辑器中的角色创建、编辑、节点添加、音频试听功能测试",
  "features": [
    {
      "id": "character_001",
      "name": "创建角色功能",
      "description": "验证用户可以创建新角色，输入角色信息、上传参考图和参考音频后保存成功",
      "priority": "P0",
      "page_url": "/video-workflow",
      "api_endpoint": "POST /api/characters/create",
      "pass": false,
      "remark": "",
      "prerequisites": [
        "world_001"
      ],
      "test_steps": [
        {
          "step": 1,
          "action": "点击角色按钮",
          "mcp_tool": "mcp1_browser_click",
          "mcp_params": {
            "element": "角色按钮",
            "ref": "<角色按钮ref>"
          },
          "expected_result": "弹出角色选择下拉框",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 2,
          "action": "点击新建角色选项",
          "mcp_tool": "mcp1_browser_click",
          "mcp_params": {
            "element": "新建角色选项",
            "ref": "<新建角色选项ref>"
          },
          "expected_result": "弹出创建角色模态框",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 3,
          "action": "填写角色基本信息",
          "mcp_tool": "mcp1_browser_fill_form",
          "mcp_params": {
            "fields": [
              {
                "name": "角色名称",
                "type": "textbox",
                "ref": "<名称输入框ref>",
                "value": "测试角色"
              },
              {
                "name": "年龄",
                "type": "textbox",
                "ref": "<年龄输入框ref>",
                "value": "25"
              },
              {
                "name": "身份",
                "type": "textbox",
                "ref": "<身份输入框ref>",
                "value": "程序员"
              },
              {
                "name": "性格",
                "type": "textbox",
                "ref": "<性格输入框ref>",
                "value": "开朗、乐观"
              }
            ]
          },
          "expected_result": "表单字段填写完成",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 4,
          "action": "上传参考图",
          "mcp_tool": "mcp1_browser_file_upload",
          "mcp_params": {
            "paths": [
              "${config.test_assets.test_image}"
            ]
          },
          "expected_result": "图片上传成功",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 5,
          "action": "上传参考音频",
          "mcp_tool": "mcp1_browser_file_upload",
          "mcp_params": {
            "paths": [
              "${config.test_assets.test_voice}"
            ]
          },
          "expected_result": "音频上传成功",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 6,
          "action": "验证音频预览播放器显示",
          "mcp_tool": "mcp1_browser_snapshot",
          "mcp_params": {},
          "verify": "音频预览区域可见，显示音频播放器控件",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 7,
          "action": "点击保存按钮",
          "mcp_tool": "mcp1_browser_click",
          "mcp_params": {
            "element": "保存按钮",
            "ref": "<保存按钮ref>"
          },
          "expected_result": "发起创建请求",
          "pass": false,
          "remark": "",
          "is_processed": false
        },
        {
          "step": 8,
          "action": "等待创建成功",
          "mcp_tool": "mcp1_browser_wait_for",
          "mcp_params": {
            "text": "创建成功",
            "time": 5
          },
          "expected_result": "显示成功提示",
          "pass": false,
          "remark": "",
          "is_processed": false
        }
      ],
      "is_processed": false
    },
